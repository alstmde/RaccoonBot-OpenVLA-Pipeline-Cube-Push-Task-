    <!-- Green cube object -->
    <body name="target_cube_green" pos="0.12 0.22 0.02">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="0.00000001 0.00000001 0.00000001"/>
      <geom name="geom_cube_green" type="box" size="0.01 0.01 0.01"
        rgba="0 1 0 1"
        friction="0.4 0.02 0.002" condim="6"
        solimp="0.99 0.99 0.001" solref="0.002 1"/>
    </body>


  </worldbody>
